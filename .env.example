# Runtime
NODE_ENV=development
PORT=4000
DB_PATH=server/data/igu.sqlite

# Initial admin bootstrap.
# Development: if users are missing, admin/admin123 is created when these are empty.
# Production: defaults are disabled; provide these only for the first active admin bootstrap.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-this-strong-password

# Optional initial SMM bootstrap.
# Development: if users are missing, smm/smm123 is created when these are empty.
SMM_LOGIN=smm
SMM_PASSWORD=change-this-strong-smm-password

# Production origin protection for cookie-authenticated POST/PUT/PATCH/DELETE requests.
# Use your public site URL; ALLOWED_ORIGINS can contain multiple comma-separated origins.
PUBLIC_SITE_ORIGIN=https://example.edu.kg
ALLOWED_ORIGINS=https://example.edu.kg
